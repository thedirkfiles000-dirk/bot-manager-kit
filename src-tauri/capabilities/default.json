{
  "identifier": "default",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "store:default",
    "dialog:default",
    "clipboard-manager:allow-write-text",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-watch",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        }
      ]
    }
  ]
}
