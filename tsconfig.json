{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",  // Ensure this is "bundler" (Vite default) or "node"
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vite/client", "node"],
    "paths": {  // Added: Mirrors Vite alias for TS/IDE resolution of @/
      "@/*": ["./src/*"]
    }
  },
  "vueCompilerOptions": {  // Added: Enhances Vue SFC type checking
    "target": 3.4  // Matches Vue 3.4+ (adjust if using older)
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "vite.config.ts"],  // Added vite.config.ts
}